# RHCM 5/15/2026: Required for EAS Build. lucide-react-native@0.475.0 declares
# peer react ^16 || ^17 || ^18, but Expo SDK 54 ships react 19. The local install
# used --legacy-peer-deps; EAS runs `npm ci` which doesn't pick that up from the
# CLI, so we set it here. Safe to remove once lucide-react-native is bumped to a
# version that lists react 19 in its peer range.
legacy-peer-deps=true
